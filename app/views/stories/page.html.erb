<div class="story-page">
  <div class="story-page__inner">
    <header class="story-page__header">
      <h1 class="story-page__title">Today’s events</h1>

      <% if @story["source"].present? || @story["fetched_at"].present? %>
        <p class="story-page__meta">
          <% if @story["source"].present? %>
            from <span>@<%= @story["source"] %></span>
          <% end %>

          <% if @story["fetched_at"].present? %>
            <span class="story-page__meta-separator">•</span>
            last calculated at
            <span>
              <%= Time.zone.parse(@story["fetched_at"]).strftime("%H:%M") rescue @story["fetched_at"] %>
            </span>
          <% end %>
        </p>
      <% end %>
    </header>

    <% if @story["active"] && @story["items"].present? %>
      <section class="story-grid">
        <% @story["items"].sort_by { |item| item["order"] || item[:order] || 0 }.each do |item| %>
          <% type = item["type"] || item[:type] %>
          <% media_url = item["media_url"] || item[:media_url] %>
          <% fallback_image_url = item["fallback_image_url"] || item[:fallback_image_url] %>
          <% order = item["order"] || item[:order] %>

          <article
            class="story-card"
            aria-label="Story <%= order %>"
            <% if type == "image" %>
            data-lightbox-type="image"
            data-lightbox-media="<%= media_url %>"
            <% elsif type == "video" %>
            data-lightbox-type="video"
            data-lightbox-media="<%= media_url %>"
            <% if fallback_image_url.present? %>
            data-lightbox-fallback="<%= fallback_image_url %>"
            <% end %>
            <% end %>
            >
            <div class="story-card__media">
              <% if type == "image" %>
                <img
                  src="<%= media_url %>"
                  alt="Story image <%= order %>"
                  class="story-card__img"
                  />
              <% elsif type == "video" %>
                <div
                  class="story-card__video-shell"
                  data-fallback-image="<%= fallback_image_url %>"
                >
                  <video
                    class="story-card__video story-card__autoplay-video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  >
                    <source src="<%= media_url %>">
                  </video>
                </div>
              <% else %>
                <div class="story-card__unsupported">
                  Unsupported story item type.
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <div class="story-empty">
        <p>No active story right now.</p>
      </div>
    <% end %>
  </div>
</div>

<div class="story-lightbox" id="story-lightbox" aria-hidden="true">
  <div class="story-lightbox__backdrop"></div>

  <div class="story-lightbox__dialog" role="dialog" aria-modal="true" aria-label="Expanded story image">
    <button class="story-lightbox__close" type="button" aria-label="Close image viewer">×</button>
    <img class="story-lightbox__image" src="" alt="Expanded story image" />
    <video class="story-lightbox__video" controls autoplay muted loop playsinline preload="metadata" hidden></video>
  </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const lightbox = document.getElementById("story-lightbox");
        const lightboxImage = lightbox?.querySelector(".story-lightbox__image");
        const lightboxVideo = lightbox?.querySelector(".story-lightbox__video");
        const closeButton = lightbox?.querySelector(".story-lightbox__close");
        const backdrop = lightbox?.querySelector(".story-lightbox__backdrop");
        const clickableCards = document.querySelectorAll("[data-lightbox-media]");
        const videoShells = document.querySelectorAll(".story-card__video-shell");

        const openLightbox = (type, src, fallbackSrc) => {
            if (!lightbox || !lightboxImage || !lightboxVideo || !src) return;

            lightboxImage.hidden = true;
            lightboxImage.src = "";
            lightboxVideo.hidden = true;
            lightboxVideo.pause();
            lightboxVideo.removeAttribute("src");
            lightboxVideo.poster = fallbackSrc || "";
            lightboxVideo.load();

            if (type === "video") {
                lightboxVideo.src = src;
                lightboxVideo.hidden = false;
                lightboxVideo.load();
                lightboxVideo.play().catch(() => {
                    if (!fallbackSrc) return;

                    lightboxVideo.hidden = true;
                    lightboxImage.src = fallbackSrc;
                    lightboxImage.hidden = false;
                });
            } else {
                lightboxImage.src = src;
                lightboxImage.hidden = false;
            }

            lightbox.classList.add("is-open");
            lightbox.setAttribute("aria-hidden", "false");
            document.body.classList.add("story-lightbox-open");
        };

        const closeLightbox = () => {
            if (!lightbox || !lightboxImage || !lightboxVideo) return;
            lightbox.classList.remove("is-open");
            lightbox.setAttribute("aria-hidden", "true");
            lightboxImage.src = "";
            lightboxImage.hidden = true;
            lightboxVideo.pause();
            lightboxVideo.removeAttribute("src");
            lightboxVideo.poster = "";
            lightboxVideo.hidden = true;
            lightboxVideo.load();
            document.body.classList.remove("story-lightbox-open");
        };

        const replaceWithFallback = (shell, fallbackSrc) => {
            if (!fallbackSrc) return;

            shell.innerHTML = "";

            const img = document.createElement("img");
            img.src = fallbackSrc;
            img.alt = "Story fallback image";
            img.className = "story-card__img";

            shell.appendChild(img);
            shell.dataset.videoFailed = "true";
        };

        clickableCards.forEach((card) => {
            card.addEventListener("click", function () {
                const type = card.getAttribute("data-lightbox-type") || "image";
                const src = card.getAttribute("data-lightbox-media");
                const fallbackSrc = card.getAttribute("data-lightbox-fallback");
                if (src) openLightbox(type, src, fallbackSrc);
            });

            card.style.cursor = "zoom-in";
        });

        closeButton?.addEventListener("click", closeLightbox);
        backdrop?.addEventListener("click", closeLightbox);

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && lightbox?.classList.contains("is-open")) {
                closeLightbox();
            }
        });

        videoShells.forEach((shell) => {
            const video = shell.querySelector("video");
            const fallbackSrc = shell.dataset.fallbackImage;

            if (!video) return;

            video.addEventListener("error", () => replaceWithFallback(shell, fallbackSrc));

            video.addEventListener("loadedmetadata", () => {
                const invalidDuration = !video.duration || !isFinite(video.duration) || video.duration <= 0;
                const invalidSize = !video.videoWidth || !video.videoHeight;

                if (invalidDuration || invalidSize) {
                    replaceWithFallback(shell, fallbackSrc);
                }
            });

            video.play().catch(() => replaceWithFallback(shell, fallbackSrc));
        });
    });
</script>
